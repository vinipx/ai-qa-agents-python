# ============================================================
# AI-Powered Multi-Agent QE Framework Configuration
# ============================================================

# --- LLM Provider Configuration ---
# Options: 'openai', 'anthropic', 'google', 'groq', 'ollama' (for local LLMs)
LLM_PROVIDER=openai

# Specific model name to use
# Examples (Latest as of March 2026):
# - OpenAI: 'gpt-5.4', 'gpt-5.3-garlic'
# - Anthropic: 'claude-4.6-opus', 'claude-4.6-sonnet'
# - Google (Gemini): 'gemini-3.1-pro', 'gemini-3.1-flash-lite'
# - Groq: 'llama-4-scout', 'gpt-oss-120b'
# - Ollama (Local): 'llama4', 'mistral-v2', 'phi4'
MODEL_NAME=gpt-5.4

# --- API Keys ---
# Required for OpenAI provider
OPENAI_API_KEY=your_openai_api_key_here

# Required for Anthropic provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for Google (Gemini) provider
GOOGLE_API_KEY=your_google_api_key_here

# Required for Groq provider
GROQ_API_KEY=your_groq_api_key_here

# --- Requirement Tracking (JIRA) ---
# The base URL of your Jira instance (e.g., https://company.atlassian.net)
JIRA_URL=https://your-domain.atlassian.net

# Personal Access Token or API Token for Jira authentication
JIRA_TOKEN=your_jira_access_token

# --- Repository Settings ---
# The git hosting provider. Options: 'github', 'gitlab', 'bitbucket'
REPO_PROVIDER=github

# The full URL to the target repository where agents will propose changes
REPO_URL=https://github.com/username/repo

# Personal Access Token with 'repo' scope for the chosen provider
REPO_TOKEN=your_repo_access_token

# --- Observability & Telemetry (LangSmith) ---
# Set to 'true' to enable LangChain tracing for debugging and observability
LANGCHAIN_TRACING_V2=true

# Your LangSmith API Key (get it from https://smith.langchain.com/)
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# The project name that will appear in the LangSmith dashboard
LANGCHAIN_PROJECT=ai-qa-agents
